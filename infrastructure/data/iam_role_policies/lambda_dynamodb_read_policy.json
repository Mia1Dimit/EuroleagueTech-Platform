{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Effect": "Allow",
      "Action": [
        "dynamodb:GetItem",
        "dynamodb:Query",
        "dynamodb:Scan"
      ],
      "Resource": [
        "arn:aws:dynamodb:eu-west-1:*:table/spotech-dev-main",
        "arn:aws:dynamodb:eu-west-1:*:table/spotech-dev-main/index/*"
      ]
    }
  ]
}